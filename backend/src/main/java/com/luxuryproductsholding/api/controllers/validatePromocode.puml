@startuml
autonumber

actor Client
participant "PromocodeController" as Controller
participant "PromocodeService" as Service
participant "PromocodeRepository" as Repo
participant "ProductRepository" as ProductRepo
participant "PromocodeValidatorService" as Validator

Client -> Controller: POST /promocodes/validateAndApply\n(RequestBody dto)
Controller -> Service: validatePromocode(dto)
Service -> Repo: findByCode(dto.code)
alt Promocode not found
    Repo --> Service: throws IllegalArgumentException("Promocode bestaat niet")
    Service --> Controller: throws IllegalArgumentException
    Controller --> Client: 200 OK\n{success: false, message: "..."}
else Promocode found
    Repo --> Service: promocode
    Service -> ProductRepo: findById(item.productId) (for each cart item)
    alt Product not found
        ProductRepo --> Service: throws IllegalArgumentException("Product ID ... niet gevonden")
        Service --> Controller: throws IllegalArgumentException
        Controller --> Client: 200 OK\n{success: false, message: "..."}
    else All products found
        ProductRepo --> Service: product(s)
        Service -> Validator: validate(promocode, dummyOrder, dto.email)
        alt Not valid
            Validator --> Service: false
            Service --> Controller: throws IllegalArgumentException("Promocode is niet geldig voor deze bestelling")
            Controller --> Client: 200 OK\n{success: false, message: "..."}
        else Valid
            Validator --> Service: true
            Service -> Validator: applyDiscount(promocode, dummyOrder, dto.email)
            Validator --> Service: korting
            Service --> Controller: new PromocodeResponse(korting, true, "Promocode toegepast")
            Controller --> Client: 200 OK\n{success: true, ...}
        end
    end
end

@enduml
