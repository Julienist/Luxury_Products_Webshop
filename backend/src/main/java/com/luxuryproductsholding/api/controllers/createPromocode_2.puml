@startuml
'https://plantuml.com/sequence-diagram

autonumber

actor Client
participant "PromocodeController" as Controller
participant "PromocodeService" as Service
participant "PromocodeValidatorService" as Validator
participant "ProductRepository" as ProductRepo
participant "CategoryRepository" as CategoryRepo
participant "PromocodeRepository" as PromoRepo

Client -> Controller: POST /promocodes\n@RequestBody PromocodeRequest
alt try block
    Controller -> Service: createPromocodeAfterValidation(promocodeRequest)
    Service -> Validator: validatePromocodeOnCreation(dto)
    alt validation fails
        Validator --> Service: throws IllegalArgumentException
        Service --> Controller: throws IllegalArgumentException
        Controller --> Client: 400 Bad Request\n(validation error)
    else validation ok
        Validator --> Service: (validation done)
        alt dto.scopeType == PRODUCT
            Service -> ProductRepo: findByName(scopeValue)
            alt product not found
                ProductRepo --> Service: throws IllegalStateException
                Service --> Controller: throws IllegalArgumentException
                Controller --> Client: 400 Bad Request\n(product not found)
            else product found
                ProductRepo --> Service: Product
            end
        else dto.scopeType == CATEGORY
            Service -> CategoryRepo: findByName(scopeValue)
            alt category not found
                CategoryRepo --> Service: throws IllegalStateException
                Service --> Controller: throws IllegalArgumentException
                Controller --> Client: 400 Bad Request\n(category not found)
            else category found
                CategoryRepo --> Service: Category
            end
        end
        note right: Service creates new Promocode\nand fills all fields
        Service -> PromoRepo: save(newPromocode)
        PromoRepo --> Service: (saved Promocode)
        Service --> Controller: (void)
        Controller --> Client: 200 OK\n"Promocode is valid and created."
    end
end
@enduml
